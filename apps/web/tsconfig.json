{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@toolbox/ui-kit": ["../../packages/ui-kit/src/index.ts"],
      "@toolbox/tool-json": ["../../tools/tool-json"],
      "@toolbox/tool-json/*": ["../../tools/tool-json/*"],
      "@toolbox/tool-ip-query": ["../../tools/tool-ip-query"],
      "@toolbox/tool-ip-query/*": ["../../tools/tool-ip-query/*"],
      "@toolbox/tool-ip-asn": ["../../tools/tool-ip-asn"],
      "@toolbox/tool-ip-asn/*": ["../../tools/tool-ip-asn/*"],
      "@toolbox/tool-dns-trace": ["../../tools/tool-dns-trace"],
      "@toolbox/tool-dns-trace/*": ["../../tools/tool-dns-trace/*"],
      "@toolbox/tool-dns-propagation": ["../../tools/tool-dns-propagation"],
      "@toolbox/tool-dns-propagation/*": ["../../tools/tool-dns-propagation/*"]
    },

    /* Linting */
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
