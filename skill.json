{
  "name": "toolbox-cloudflare",
  "version": "1.0.0",
  "description": "Toolbox网站Cloudflare CDN配置和部署技能",
  "author": "Super Chao",
  "category": "devops",
  "tags": ["cloudflare", "cdn", "deployment", "ssl"],
  "features": [
    "Cloudflare DNS解析配置",
    "SSL/TLS证书管理",
    "CDN缓存优化",
    "DDoS防护",
    "WAF安全配置",
    "页面规则优化"
  ],
  "prerequisites": [
    "Cloudflare账号",
    "已注册的域名",
    "EC2实例公网IP"
  ],
  "installation": {
    "steps": [
      "1. 在Cloudflare控制台添加域名",
      "2. 按照CLOUDFLARE_SETUP.md配置DNS记录",
      "3. 配置SSL/TLS和页面规则",
      "4. 等待DNS生效后访问测试"
    ]
  },
  "files": [
    "CLOUDFLARE_SETUP.md",
    "wrangler.toml",
    "workers/ai-proxy.ts"
  ]
}
