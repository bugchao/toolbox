{
  "name": "toolbox",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "create:tool": "node scripts/create-tool.cjs",
    "dev": "pnpm -C apps/web dev",
    "build": "pnpm -C apps/web build",
    "lint": "pnpm -C apps/web lint",
    "preview": "pnpm -C apps/web preview",
    "start": "node server.js",
    "crawl:news": "tsx crawler/news_crawler.ts --output apps/web/public/news.json",
    "docker:build": "docker build -t toolbox:latest .",
    "docker:run": "docker run -d -p 3000:3000 --name toolbox --restart unless-stopped toolbox:latest",
    "docker:deploy": "pnpm run docker:build && (docker stop toolbox 2>/dev/null || true) && (docker rm toolbox 2>/dev/null || true) && pnpm run docker:run",
    "docker:stop": "docker stop toolbox 2>/dev/null || true",
    "aws:deploy": "bash scripts/deploy-aws-ec2.sh",
    "test": "pnpm -C apps/web test:run",
    "test:watch": "pnpm -C apps/web test",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=$HOME/.cache/ms-playwright playwright test",
    "test:e2e:ui": "PLAYWRIGHT_BROWSERS_PATH=$HOME/.cache/ms-playwright playwright test --ui --ui-host=127.0.0.1",
    "test:e2e:ui:install": "PLAYWRIGHT_BROWSERS_PATH=$HOME/.cache/ms-playwright playwright install chromium",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "express": "^4.18.2",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
